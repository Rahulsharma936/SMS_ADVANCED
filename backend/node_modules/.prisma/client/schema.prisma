generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// PHASE 1: Foundation & Auth (LOCKED)
// ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String? // Optional for future subdomain approach
  code      String? // Short code for admission numbers e.g. "SPH"
  createdAt DateTime @default(now())

  users    User[]
  roles    Role[]
  students Student[]
  teachers Teacher[]

  // Phase 2 relations
  classes              Class[]
  sections             Section[]
  subjects             Subject[]
  teacherSubjects      TeacherSubject[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetables           Timetable[]
  timetableSlots       TimetableSlot[]
  attendanceSessions   AttendanceSession[]
  attendanceRecords    AttendanceRecord[]
  leaveApplications    LeaveApplication[]
  notifications        Notification[]
  biometricLogs        BiometricLog[]

  // Phase 3 relations
  parents            Parent[]
  studentParents     StudentParent[]
  studentDocuments   StudentDocument[]
  transferHistories  TransferHistory[]
  auditLogs          AuditLog[]
  admissionSequences AdmissionSequence[]
  siblingLinks       SiblingLink[]

  // Phase 4 relations
  syllabi            Syllabus[]
  syllabusTopics     SyllabusTopic[]
  curriculumProgress CurriculumProgress[]
  academicEvents     AcademicEvent[]

  // Phase 6 relations
  exams           Exam[]
  examSubjects    ExamSubject[]
  studentExams    StudentExam[]
  marksEntries    MarksEntry[]
  gradeScales     GradeScale[]
  resultSummaries ResultSummary[]
  reportCards     ReportCard[]

  // Phase 7: Fee Management
  feeStructures       FeeStructure[]
  feeComponents       FeeComponent[]
  feeDiscounts        FeeDiscount[]
  studentFees         StudentFee[]
  studentFeeDiscounts StudentFeeDiscount[]
  feeInstallments     FeeInstallment[]

  // Phase 8: Payment Engine
  feePayments        FeePayment[]
  paymentAllocations PaymentAllocation[]

  // Phase 9: Receipts & Reporting
  feeReceipts  FeeReceipt[]
  feeInvoices  FeeInvoice[]
  reminderLogs ReminderLog[]

  // Phase 10: Communication System
  announcements         Announcement[]
  notices               Notice[]
  inAppNotifications    InAppNotification[]
  notificationTemplates NotificationTemplate[]
  notificationQueues    NotificationQueue[]

  // Phase 11: Chat System
  conversations            Conversation[]
  conversationParticipants ConversationParticipant[]
  messages                 Message[]

  @@map("tenants")
}

model Role {
  id        String @id @default(uuid())
  name      String // "Admin", "Teacher", "Student", "Parent"
  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  users User[]

  @@index([tenant_id])
  @@map("roles")
}

model User {
  id        String   @id @default(uuid())
  tenant_id String
  tenant    Tenant   @relation(fields: [tenant_id], references: [id])
  email     String
  password  String
  role_id   String
  role      Role     @relation(fields: [role_id], references: [id])
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())

  students                 Student[]
  teachers                 Teacher[]
  auditLogs                AuditLog[]
  paymentsCreated          FeePayment[]              @relation("PaymentCreatedBy")
  receiptsGenerated        FeeReceipt[]              @relation("ReceiptGeneratedBy")
  announcements            Announcement[]            @relation("AnnouncementCreatedBy")
  notices                  Notice[]                  @relation("NoticeCreatedBy")
  inAppNotifications       InAppNotification[]       @relation("UserInAppNotifications")
  conversationParticipants ConversationParticipant[] @relation("UserConversations")
  sentMessages             Message[]                 @relation("MessageSender")
  messageStatuses          MessageStatus[]           @relation("UserMessageStatuses")

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@map("users")
}

model Student {
  id        String @id @default(uuid())
  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  // Optional: User account created LATER for student login (not at admission)
  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  // ─── Core Identity ───
  admission_number String
  firstName        String
  lastName         String
  dateOfBirth      DateTime?
  gender           String? // "Male", "Female", "Other"
  blood_group      String? // "A+", "B-", "O+", etc.
  profilePhotoUrl  String?

  // ─── Academic Placement ───
  class_id      String
  class         Class   @relation(fields: [class_id], references: [id])
  section_id    String
  section       Section @relation(fields: [section_id], references: [id])
  roll_number   String?
  academic_year String? // "2025-2026"

  // ─── Parent/Guardian (flat fields kept for backward compat, relational Parent model preferred) ───
  fatherName      String?
  motherName      String?
  guardianContact String?
  guardianEmail   String?

  // ─── Address ───
  addressLine String?
  city        String?
  state       String?
  postalCode  String?

  // ─── Medical ───
  allergies         String?
  chronicConditions String?
  emergencyNotes    String?

  // ─── Transport ───
  transportRequired Boolean @default(false)

  // ─── Meta ───
  admissionDate DateTime  @default(now())
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE, TRANSFERRED, GRADUATED, WITHDRAWN
  deletedAt     DateTime? // Soft delete

  // ─── Relations ───
  attendanceRecords AttendanceRecord[]
  leaveApplications LeaveApplication[]
  biometricLogs     BiometricLog[]
  studentExams      StudentExam[]
  studentParents    StudentParent[]
  documents         StudentDocument[]
  transfersFrom     TransferHistory[]  @relation("TransferFrom")
  siblingLinksA     SiblingLink[]      @relation("SiblingA")
  siblingLinksB     SiblingLink[]      @relation("SiblingB")
  studentFees       StudentFee[]
  feePayments       FeePayment[]
  reminderLogs      ReminderLog[]

  @@unique([tenant_id, admission_number])
  @@unique([tenant_id, class_id, section_id, roll_number])
  @@index([tenant_id])
  @@index([class_id])
  @@index([section_id])
  @@index([deletedAt])
  @@map("students")
}

model Teacher {
  id          String @id @default(uuid())
  tenant_id   String
  tenant      Tenant @relation(fields: [tenant_id], references: [id])
  user_id     String
  user        User   @relation(fields: [user_id], references: [id])
  employee_id String

  // Basic profile fields
  firstName String
  lastName  String

  // Professional info (Phase 5 extension)
  joining_date     DateTime?
  qualification    String?
  experience_years Int?
  specialization   String? // e.g. "Mathematics, Physics"
  designation      String? // e.g. "Senior Teacher", "HOD", "PGT"
  phone            String?
  status           String    @default("active") // active, inactive, on_leave

  // Phase 2 relations
  teacherSubjects      TeacherSubject[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetableSlots       TimetableSlot[]

  // Phase 4: class teacher assignment
  classTeacherSections Section[] @relation("ClassTeacher")

  // Phase 5: attendance tracking
  markedSessions     AttendanceSession[]  @relation("MarkedBy")
  approvedLeaves     LeaveApplication[]   @relation("ApprovedBy")
  curriculumProgress CurriculumProgress[]

  @@unique([tenant_id, employee_id])
  @@index([tenant_id])
  @@map("teachers")
}

// ─────────────────────────────────────────────
// PHASE 2: Core Academic Modules
// ─────────────────────────────────────────────

model Class {
  id            String  @id @default(uuid())
  tenant_id     String
  tenant        Tenant  @relation(fields: [tenant_id], references: [id])
  name          String // e.g. "Grade 10", "Class 12"
  description   String?
  academic_year String? // "2025-2026"
  is_active     Boolean @default(true)

  sections             Section[]
  students             Student[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetables           Timetable[]
  attendanceSessions   AttendanceSession[]
  transfersTo          TransferHistory[]     @relation("TransferToClass")
  transfersFrom        TransferHistory[]     @relation("TransferFromClass")
  syllabi              Syllabus[]
  academicEvents       AcademicEvent[]
  studentExams         StudentExam[]
  feeStructures        FeeStructure[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("classes")
}

model Section {
  id               String   @id @default(uuid())
  tenant_id        String
  tenant           Tenant   @relation(fields: [tenant_id], references: [id])
  class_id         String
  class            Class    @relation(fields: [class_id], references: [id])
  name             String // e.g. "A", "B", "C"
  class_teacher_id String? // Class teacher assigned to this section
  classTeacher     Teacher? @relation("ClassTeacher", fields: [class_teacher_id], references: [id])

  students             Student[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetables           Timetable[]
  attendanceSessions   AttendanceSession[]
  transfersTo          TransferHistory[]     @relation("TransferToSection")
  transfersFrom        TransferHistory[]     @relation("TransferFromSection")
  studentExams         StudentExam[]

  @@unique([tenant_id, class_id, name])
  @@index([tenant_id])
  @@index([class_id])
  @@map("sections")
}

model Subject {
  id        String  @id @default(uuid())
  tenant_id String
  tenant    Tenant  @relation(fields: [tenant_id], references: [id])
  name      String // e.g. "Mathematics", "Physics"
  code      String? // e.g. "MATH101"
  type      String  @default("core") // "core", "elective"

  teacherSubjects      TeacherSubject[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetableSlots       TimetableSlot[]
  syllabi              Syllabus[]
  examSubjects         ExamSubject[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("subjects")
}

// Many-to-many: Teacher <-> Subject
model TeacherSubject {
  id         String  @id @default(uuid())
  tenant_id  String
  tenant     Tenant  @relation(fields: [tenant_id], references: [id])
  teacher_id String
  teacher    Teacher @relation(fields: [teacher_id], references: [id])
  subject_id String
  subject    Subject @relation(fields: [subject_id], references: [id])

  @@unique([tenant_id, teacher_id, subject_id])
  @@index([tenant_id])
  @@map("teacher_subjects")
}

// Junction: Which teacher teaches which subject in which class+section
model ClassSubjectTeacher {
  id         String  @id @default(uuid())
  tenant_id  String
  tenant     Tenant  @relation(fields: [tenant_id], references: [id])
  class_id   String
  class      Class   @relation(fields: [class_id], references: [id])
  section_id String
  section    Section @relation(fields: [section_id], references: [id])
  subject_id String
  subject    Subject @relation(fields: [subject_id], references: [id])
  teacher_id String
  teacher    Teacher @relation(fields: [teacher_id], references: [id])

  @@unique([tenant_id, class_id, section_id, subject_id])
  @@index([tenant_id])
  @@index([class_id])
  @@index([section_id])
  @@map("class_subject_teachers")
}

// ─── Timetable ───

model Timetable {
  id            String  @id @default(uuid())
  tenant_id     String
  tenant        Tenant  @relation(fields: [tenant_id], references: [id])
  class_id      String
  class         Class   @relation(fields: [class_id], references: [id])
  section_id    String
  section       Section @relation(fields: [section_id], references: [id])
  day_of_week   String // "Monday", "Tuesday", etc.
  academic_year String? // "2025-2026"

  slots TimetableSlot[]

  @@unique([tenant_id, class_id, section_id, day_of_week])
  @@index([tenant_id])
  @@map("timetables")
}

model TimetableSlot {
  id            String    @id @default(uuid())
  tenant_id     String
  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
  timetable_id  String
  timetable     Timetable @relation(fields: [timetable_id], references: [id])
  subject_id    String
  subject       Subject   @relation(fields: [subject_id], references: [id])
  teacher_id    String
  teacher       Teacher   @relation(fields: [teacher_id], references: [id])
  start_time    String // "09:00"
  end_time      String // "09:45"
  period_number Int? // 1, 2, 3... for ordering

  @@unique([timetable_id, start_time, end_time]) // No overlapping slots per timetable
  @@index([tenant_id])
  @@index([timetable_id])
  @@index([teacher_id])
  @@map("timetable_slots")
}

// ─── Attendance ───

model AttendanceSession {
  id           String   @id @default(uuid())
  tenant_id    String
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  class_id     String
  class        Class    @relation(fields: [class_id], references: [id])
  section_id   String
  section      Section  @relation(fields: [section_id], references: [id])
  date         DateTime
  period       Int? // null = daily attendance, 1-8 = period-wise
  marked_by_id String? // Teacher who marked
  markedBy     Teacher? @relation("MarkedBy", fields: [marked_by_id], references: [id])
  source       String   @default("manual") // manual, biometric
  created_at   DateTime @default(now())

  records AttendanceRecord[]

  @@unique([tenant_id, class_id, section_id, date, period])
  @@index([tenant_id])
  @@index([class_id])
  @@index([section_id])
  @@index([date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id         String            @id @default(uuid())
  tenant_id  String
  tenant     Tenant            @relation(fields: [tenant_id], references: [id])
  session_id String
  session    AttendanceSession @relation(fields: [session_id], references: [id])
  student_id String
  student    Student           @relation(fields: [student_id], references: [id])
  status     String // "PRESENT", "ABSENT", "LATE", "EXCUSED"
  remarks    String?

  @@unique([session_id, student_id])
  @@index([tenant_id])
  @@index([session_id])
  @@index([student_id])
  @@map("attendance_records")
}

// ─────────────────────────────────────────────
// PHASE 3: Student Management Extensions
// ─────────────────────────────────────────────

// ─── Parent (relational, separate from Student) ───

model Parent {
  id         String  @id @default(uuid())
  tenant_id  String
  tenant     Tenant  @relation(fields: [tenant_id], references: [id])
  name       String
  phone      String?
  email      String?
  occupation String?

  studentParents StudentParent[]

  @@index([tenant_id])
  @@index([phone])
  @@map("parents")
}

model StudentParent {
  id                   String  @id @default(uuid())
  tenant_id            String
  tenant               Tenant  @relation(fields: [tenant_id], references: [id])
  student_id           String
  student              Student @relation(fields: [student_id], references: [id])
  parent_id            String
  parent               Parent  @relation(fields: [parent_id], references: [id])
  relation             String // "father", "mother", "guardian"
  is_emergency_contact Boolean @default(false)

  @@unique([student_id, parent_id])
  @@index([tenant_id])
  @@map("student_parents")
}

// ─── Student Documents ───

model StudentDocument {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  student_id String
  student    Student  @relation(fields: [student_id], references: [id])
  name       String // "Birth Certificate", "Transfer Certificate"
  url        String
  createdAt  DateTime @default(now())

  @@index([tenant_id])
  @@index([student_id])
  @@map("student_documents")
}

// ─── Transfer History ───

model TransferHistory {
  id             String   @id @default(uuid())
  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  student_id     String
  student        Student  @relation("TransferFrom", fields: [student_id], references: [id])
  old_class_id   String
  old_class      Class    @relation("TransferFromClass", fields: [old_class_id], references: [id])
  new_class_id   String
  new_class      Class    @relation("TransferToClass", fields: [new_class_id], references: [id])
  old_section_id String
  old_section    Section  @relation("TransferFromSection", fields: [old_section_id], references: [id])
  new_section_id String
  new_section    Section  @relation("TransferToSection", fields: [new_section_id], references: [id])
  reason         String?
  transferDate   DateTime @default(now())

  @@index([tenant_id])
  @@index([student_id])
  @@map("transfer_histories")
}

// ─── Audit Log ───

model AuditLog {
  id        String   @id @default(uuid())
  tenant_id String
  tenant    Tenant   @relation(fields: [tenant_id], references: [id])
  user_id   String
  user      User     @relation(fields: [user_id], references: [id])
  action    String // "CREATE", "UPDATE", "DELETE", "TRANSFER", "PROMOTE"
  entity    String // "Student", "Class", etc.
  entity_id String
  changes   Json? // { before: {}, after: {} }
  createdAt DateTime @default(now())

  @@index([tenant_id])
  @@index([entity, entity_id])
  @@map("audit_logs")
}

// ─── Admission Number Sequence ───

model AdmissionSequence {
  id            String @id @default(uuid())
  tenant_id     String
  tenant        Tenant @relation(fields: [tenant_id], references: [id])
  academic_year String // "2025-2026"
  last_sequence Int    @default(0)

  @@unique([tenant_id, academic_year])
  @@map("admission_sequences")
}

// ─── Sibling Links ───

model SiblingLink {
  id        String  @id @default(uuid())
  tenant_id String
  tenant    Tenant  @relation(fields: [tenant_id], references: [id])
  student_a String
  studentA  Student @relation("SiblingA", fields: [student_a], references: [id])
  student_b String
  studentB  Student @relation("SiblingB", fields: [student_b], references: [id])

  @@unique([student_a, student_b])
  @@index([tenant_id])
  @@map("sibling_links")
}

// ─────────────────────────────────────────────
// PHASE 4: Academic Management
// ─────────────────────────────────────────────

// ─── Syllabus ───

model Syllabus {
  id            String  @id @default(uuid())
  tenant_id     String
  tenant        Tenant  @relation(fields: [tenant_id], references: [id])
  subject_id    String
  subject       Subject @relation(fields: [subject_id], references: [id])
  class_id      String
  class         Class   @relation(fields: [class_id], references: [id])
  title         String
  description   String?
  file_url      String?
  academic_year String // "2025-2026"

  topics SyllabusTopic[]

  @@unique([tenant_id, subject_id, class_id, academic_year])
  @@index([tenant_id])
  @@map("syllabi")
}

model SyllabusTopic {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  syllabus_id String
  syllabus    Syllabus @relation(fields: [syllabus_id], references: [id])
  topic_name  String
  order_index Int      @default(0)

  curriculumProgress CurriculumProgress[]

  @@index([syllabus_id])
  @@map("syllabus_topics")
}

// ─── Curriculum Progress ───

model CurriculumProgress {
  id                    String        @id @default(uuid())
  tenant_id             String
  tenant                Tenant        @relation(fields: [tenant_id], references: [id])
  subject_assignment_id String // References ClassSubjectTeacher
  topic_id              String
  topic                 SyllabusTopic @relation(fields: [topic_id], references: [id])
  completed             Boolean       @default(false)
  completed_at          DateTime?
  teacher_id            String
  teacher               Teacher       @relation(fields: [teacher_id], references: [id])

  @@unique([subject_assignment_id, topic_id])
  @@index([tenant_id])
  @@map("curriculum_progress")
}

// ─── Academic Calendar ───

model AcademicEvent {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  title       String
  description String?
  type        String // "holiday", "exam", "event", "meeting"
  start_date  DateTime
  end_date    DateTime
  class_id    String? // null = school-wide
  class       Class?   @relation(fields: [class_id], references: [id])

  @@index([tenant_id])
  @@index([start_date, end_date])
  @@map("academic_events")
}

// ─────────────────────────────────────────────
// PHASE 5: Extended Attendance Management
// ─────────────────────────────────────────────

// ─── Leave Applications ───

model LeaveApplication {
  id             String   @id @default(uuid())
  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  student_id     String
  student        Student  @relation(fields: [student_id], references: [id])
  from_date      DateTime
  to_date        DateTime
  reason         String
  status         String   @default("pending") // pending, approved, rejected
  approved_by_id String?
  approvedBy     Teacher? @relation("ApprovedBy", fields: [approved_by_id], references: [id])
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([tenant_id])
  @@index([student_id])
  @@index([status])
  @@map("leave_applications")
}

// ─── Notifications ───

model Notification {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  type       String // "absence_alert", "leave_update", "general"
  title      String
  message    String
  recipient  String // email or phone
  sent       Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([tenant_id])
  @@index([type])
  @@map("notifications")
}

// ─── Biometric Integration (Optional) ───

model BiometricLog {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  student_id String
  student    Student  @relation(fields: [student_id], references: [id])
  timestamp  DateTime
  device_id  String?
  synced     Boolean  @default(false)

  @@index([tenant_id])
  @@index([student_id])
  @@index([synced])
  @@map("biometric_logs")
}

// ─────────────────────────────────────────────
// PHASE 6: Examination & Grades System
// ─────────────────────────────────────────────

// ─── Exam ───

model Exam {
  id            String    @id @default(uuid())
  tenant_id     String
  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
  name          String // "Midterm", "Final", "Unit Test 1"
  academic_year String // "2025-2026"
  start_date    DateTime?
  end_date      DateTime?
  status        String    @default("draft") // draft, published, completed
  created_at    DateTime  @default(now())

  examSubjects ExamSubject[]
  studentExams StudentExam[]

  @@index([tenant_id])
  @@index([status])
  @@map("exams")
}

// ─── ExamSubject: Configures subjects for an exam with max/passing marks ───

model ExamSubject {
  id            String  @id @default(uuid())
  tenant_id     String
  tenant        Tenant  @relation(fields: [tenant_id], references: [id])
  exam_id       String
  exam          Exam    @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  subject_id    String
  subject       Subject @relation(fields: [subject_id], references: [id])
  max_marks     Decimal // Use Decimal for accuracy
  passing_marks Decimal
  weightage     Decimal @default(1) // For weighted average across terms

  marksEntries MarksEntry[]

  @@unique([exam_id, subject_id])
  @@index([tenant_id])
  @@map("exam_subjects")
}

// ─── StudentExam: Registers a student for an exam ───

model StudentExam {
  id         String  @id @default(uuid())
  tenant_id  String
  tenant     Tenant  @relation(fields: [tenant_id], references: [id])
  student_id String
  student    Student @relation(fields: [student_id], references: [id])
  exam_id    String
  exam       Exam    @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  class_id   String
  class      Class   @relation(fields: [class_id], references: [id])
  section_id String
  section    Section @relation(fields: [section_id], references: [id])

  marksEntries  MarksEntry[]
  resultSummary ResultSummary?
  reportCard    ReportCard?

  @@unique([student_id, exam_id])
  @@index([tenant_id])
  @@index([exam_id])
  @@index([student_id])
  @@map("student_exams")
}

// ─── MarksEntry: Individual subject marks for a student in an exam ───

model MarksEntry {
  id              String      @id @default(uuid())
  tenant_id       String
  tenant          Tenant      @relation(fields: [tenant_id], references: [id])
  student_exam_id String
  studentExam     StudentExam @relation(fields: [student_exam_id], references: [id], onDelete: Cascade)
  exam_subject_id String
  examSubject     ExamSubject @relation(fields: [exam_subject_id], references: [id], onDelete: Cascade)
  marks_obtained  Decimal // Decimal for precision
  is_absent       Boolean     @default(false)
  remarks         String?

  @@unique([student_exam_id, exam_subject_id])
  @@index([tenant_id])
  @@index([student_exam_id])
  @@map("marks_entries")
}

// ─── GradeScale: Configurable per tenant (supports CBSE, ICSE, etc.) ───

model GradeScale {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  name        String // "CBSE Grade A1", "Pass", etc.
  min_percent Decimal // Min percentage for this grade
  max_percent Decimal // Max percentage (exclusive)
  grade       String // "A1", "A2", "B1", "B2", "C", "F"
  grade_point Decimal? // For GPA systems (optional)
  remark      String? // "Excellent", "Good", etc.

  @@unique([tenant_id, grade])
  @@index([tenant_id])
  @@map("grade_scales")
}

// ─── ResultSummary: Aggregated result per student per exam ───

model ResultSummary {
  id              String      @id @default(uuid())
  tenant_id       String
  tenant          Tenant      @relation(fields: [tenant_id], references: [id])
  student_exam_id String      @unique
  studentExam     StudentExam @relation(fields: [student_exam_id], references: [id], onDelete: Cascade)
  total_marks     Decimal
  max_total       Decimal
  percentage      Decimal
  grade           String?
  grade_point     Decimal?
  rank_class      Int? // Rank within the class
  rank_section    Int? // Rank within the section
  is_pass         Boolean     @default(false)
  calculated_at   DateTime    @default(now())

  @@index([tenant_id])
  @@map("result_summaries")
}

// ─── ReportCard: Generated report card per student per exam ───

model ReportCard {
  id              String      @id @default(uuid())
  tenant_id       String
  tenant          Tenant      @relation(fields: [tenant_id], references: [id])
  student_exam_id String      @unique
  studentExam     StudentExam @relation(fields: [student_exam_id], references: [id], onDelete: Cascade)
  generated_at    DateTime    @default(now())
  pdf_url         String? // Optional: path if PDF is generated

  @@index([tenant_id])
  @@map("report_cards")
}

// ─── Subject exam relation (back-reference) ───
// Note: Subject already exists; we only need ExamSubject relation added to it

// ─────────────────────────────────────────────
// PHASE 7: Fee Management System
// ─────────────────────────────────────────────

// ─── FeeStructure: Reusable fee template per class/academic year ───

model FeeStructure {
  id            String   @id @default(uuid())
  tenant_id     String
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])
  name          String // e.g. "Class 10 Annual Fee 2025-26"
  academic_year String // "2025-2026"
  class_id      String? // null = school-wide structure
  class         Class?   @relation(fields: [class_id], references: [id])
  currency      String   @default("INR")
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  components  FeeComponent[]
  studentFees StudentFee[]

  @@index([tenant_id])
  @@index([academic_year])
  @@map("fee_structures")
}

// ─── FeeComponent: Line-item breakdown within a FeeStructure ───

model FeeComponent {
  id               String       @id @default(uuid())
  tenant_id        String
  tenant           Tenant       @relation(fields: [tenant_id], references: [id])
  fee_structure_id String
  feeStructure     FeeStructure @relation(fields: [fee_structure_id], references: [id], onDelete: Cascade)
  name             String // "Tuition Fee", "Transport Fee", "Library Fee"
  amount           Decimal      @db.Decimal(12, 2)
  tax_percentage   Decimal?     @db.Decimal(5, 2) // optional GST/tax
  is_optional      Boolean      @default(false)

  @@index([tenant_id])
  @@index([fee_structure_id])
  @@map("fee_components")
}

// ─── FeeDiscount: Reusable discount definitions ───

model FeeDiscount {
  id        String  @id @default(uuid())
  tenant_id String
  tenant    Tenant  @relation(fields: [tenant_id], references: [id])
  name      String // "Sibling Discount", "Scholarship", "Staff Child"
  type      String // "percentage" | "fixed"
  value     Decimal @db.Decimal(10, 2)
  is_active Boolean @default(true)

  studentFeeDiscounts StudentFeeDiscount[]

  @@index([tenant_id])
  @@map("fee_discounts")
}

// ─── StudentFee: Fee assignment per student ───

model StudentFee {
  id               String       @id @default(uuid())
  tenant_id        String
  tenant           Tenant       @relation(fields: [tenant_id], references: [id])
  student_id       String
  student          Student      @relation(fields: [student_id], references: [id])
  fee_structure_id String
  feeStructure     FeeStructure @relation(fields: [fee_structure_id], references: [id])
  total_amount     Decimal      @db.Decimal(12, 2) // sum of components
  discount_amount  Decimal      @default(0) @db.Decimal(12, 2)
  final_amount     Decimal      @db.Decimal(12, 2) // total - discount
  status           String       @default("pending") // pending, partial, paid, overdue
  assigned_at      DateTime     @default(now())

  discounts    StudentFeeDiscount[]
  installments FeeInstallment[]
  payments     FeePayment[]
  invoices     FeeInvoice[]

  @@index([tenant_id])
  @@index([student_id])
  @@index([fee_structure_id])
  @@index([status])
  @@map("student_fees")
}

// ─── StudentFeeDiscount: Discount applied to a specific student fee ───

model StudentFeeDiscount {
  id              String      @id @default(uuid())
  tenant_id       String
  tenant          Tenant      @relation(fields: [tenant_id], references: [id])
  student_fee_id  String
  studentFee      StudentFee  @relation(fields: [student_fee_id], references: [id], onDelete: Cascade)
  fee_discount_id String
  feeDiscount     FeeDiscount @relation(fields: [fee_discount_id], references: [id])
  applied_value   Decimal     @db.Decimal(12, 2) // actual monetary value applied

  @@index([tenant_id])
  @@index([student_fee_id])
  @@map("student_fee_discounts")
}

// ─── FeeInstallment: Planned payment schedule for a StudentFee ───

model FeeInstallment {
  id               String     @id @default(uuid())
  tenant_id        String
  tenant           Tenant     @relation(fields: [tenant_id], references: [id])
  student_fee_id   String
  studentFee       StudentFee @relation(fields: [student_fee_id], references: [id], onDelete: Cascade)
  installment_name String // "Quarter 1", "April Fee", "Term 1"
  due_date         DateTime
  amount           Decimal    @db.Decimal(12, 2)
  status           String     @default("pending") // pending, partial, paid, overdue

  allocations  PaymentAllocation[]
  reminderLogs ReminderLog[]

  @@index([tenant_id])
  @@index([student_fee_id])
  @@index([due_date])
  @@index([status])
  @@map("fee_installments")
}

// ─────────────────────────────────────────────
// PHASE 8: Payment Engine
// ─────────────────────────────────────────────

// ─── FeePayment: Represents one payment attempt / confirmation ───

model FeePayment {
  id                String     @id @default(uuid())
  tenant_id         String
  tenant            Tenant     @relation(fields: [tenant_id], references: [id])
  student_id        String
  student           Student    @relation(fields: [student_id], references: [id])
  student_fee_id    String
  studentFee        StudentFee @relation(fields: [student_fee_id], references: [id])
  amount_paid       Decimal    @db.Decimal(12, 2)
  payment_method    String // cash | upi | razorpay | cheque | dd | bank_transfer
  transaction_id    String? // unique ref for online payments (gateway txn id)
  gateway_reference String? // external order/payment id from gateway
  payment_date      DateTime   @default(now())
  status            String     @default("pending") // pending | success | failed | refunded
  remarks           String?
  created_by        String // User.id who recorded the payment
  createdBy         User       @relation("PaymentCreatedBy", fields: [created_by], references: [id])
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  allocations PaymentAllocation[]
  receipt     FeeReceipt?

  @@unique([tenant_id, transaction_id]) // prevent duplicate online payment confirmations
  @@index([tenant_id])
  @@index([student_id])
  @@index([student_fee_id])
  @@index([status])
  @@index([payment_date])
  @@map("fee_payments")
}

// ─── PaymentAllocation: Maps a payment to specific installments ───

model PaymentAllocation {
  id               String         @id @default(uuid())
  tenant_id        String
  tenant           Tenant         @relation(fields: [tenant_id], references: [id])
  payment_id       String
  payment          FeePayment     @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  installment_id   String
  installment      FeeInstallment @relation(fields: [installment_id], references: [id])
  amount_allocated Decimal        @db.Decimal(12, 2)

  @@index([tenant_id])
  @@index([payment_id])
  @@index([installment_id])
  @@map("payment_allocations")
}

// ─────────────────────────────────────────────
// PHASE 9: Receipts, Invoices & Reporting
// ─────────────────────────────────────────────

// ─── FeeReceipt: One receipt per successful payment (idempotent) ───

model FeeReceipt {
  id             String     @id @default(uuid())
  tenant_id      String
  tenant         Tenant     @relation(fields: [tenant_id], references: [id])
  payment_id     String     @unique // one receipt per payment
  payment        FeePayment @relation(fields: [payment_id], references: [id])
  receipt_number String // e.g. "REC-2025-000123"
  generated_at   DateTime   @default(now())
  generated_by   String
  generatedBy    User       @relation("ReceiptGeneratedBy", fields: [generated_by], references: [id])
  pdf_url        String?

  @@unique([tenant_id, receipt_number])
  @@index([tenant_id])
  @@index([payment_id])
  @@map("fee_receipts")
}

// ─── FeeInvoice: Represents a due notice for a StudentFee ───

model FeeInvoice {
  id             String     @id @default(uuid())
  tenant_id      String
  tenant         Tenant     @relation(fields: [tenant_id], references: [id])
  student_fee_id String
  studentFee     StudentFee @relation(fields: [student_fee_id], references: [id])
  invoice_number String
  total_due      Decimal    @db.Decimal(12, 2)
  generated_at   DateTime   @default(now())
  due_date       DateTime
  status         String     @default("pending") // pending | partial | paid | overdue

  @@unique([tenant_id, invoice_number])
  @@index([tenant_id])
  @@index([student_fee_id])
  @@index([status])
  @@map("fee_invoices")
}

// ─── ReminderLog: Tracks every reminder sent to a student ───

model ReminderLog {
  id             String         @id @default(uuid())
  tenant_id      String
  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  student_id     String
  student        Student        @relation(fields: [student_id], references: [id])
  installment_id String
  installment    FeeInstallment @relation(fields: [installment_id], references: [id])
  type           String // sms | email | whatsapp
  message        String
  sent_at        DateTime       @default(now())
  status         String         @default("sent") // sent | failed | delivered

  @@index([tenant_id])
  @@index([student_id])
  @@index([installment_id])
  @@index([sent_at])
  @@map("reminder_logs")
}

// ─────────────────────────────────────────────
// PHASE 10: Communication System
// ─────────────────────────────────────────────

model Announcement {
  id          String    @id @default(uuid())
  tenant_id   String
  tenant      Tenant    @relation(fields: [tenant_id], references: [id])
  title       String
  message     String
  created_by  String
  createdBy   User      @relation("AnnouncementCreatedBy", fields: [created_by], references: [id])
  target_type String
  target_id   String?
  created_at  DateTime  @default(now())
  expires_at  DateTime?

  @@index([tenant_id])
  @@index([target_type, target_id])
  @@index([created_at])
  @@map("announcements")
}

model Notice {
  id           String    @id @default(uuid())
  tenant_id    String
  tenant       Tenant    @relation(fields: [tenant_id], references: [id])
  title        String
  content      String
  priority     String    @default("medium")
  created_by   String
  createdBy    User      @relation("NoticeCreatedBy", fields: [created_by], references: [id])
  published_at DateTime  @default(now())
  expires_at   DateTime?

  @@index([tenant_id])
  @@index([priority])
  @@index([published_at])
  @@map("notices")
}

model InAppNotification {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  user_id    String
  user       User     @relation("UserInAppNotifications", fields: [user_id], references: [id])
  type       String
  title      String
  message    String
  is_read    Boolean  @default(false)
  ref_id     String?
  created_at DateTime @default(now())

  @@index([tenant_id])
  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
  @@map("in_app_notifications")
}

model NotificationTemplate {
  id            String   @id @default(uuid())
  tenant_id     String
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])
  name          String
  type          String
  channel       String
  template_body String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([tenant_id, name, channel])
  @@index([tenant_id])
  @@index([type, channel])
  @@map("notification_templates")
}

model NotificationQueue {
  id                String    @id @default(uuid())
  tenant_id         String
  tenant            Tenant    @relation(fields: [tenant_id], references: [id])
  type              String
  channel           String
  recipient         String
  title             String
  message           String
  status            String    @default("queued")
  retry_count       Int       @default(0)
  max_retries       Int       @default(3)
  scheduled_at      DateTime  @default(now())
  processed_at      DateTime?
  provider_response Json?
  ref_id            String?

  logs NotificationDeliveryLog[]

  @@index([tenant_id])
  @@index([status])
  @@index([channel])
  @@index([scheduled_at])
  @@map("notification_queue")
}

model NotificationDeliveryLog {
  id         String            @id @default(uuid())
  queue_id   String
  queue      NotificationQueue @relation(fields: [queue_id], references: [id], onDelete: Cascade)
  status     String
  response   Json?
  created_at DateTime          @default(now())

  @@index([queue_id])
  @@index([status])
  @@map("notification_delivery_logs")
}

// ─────────────────────────────────────────────
// PHASE 11: Realtime Chat System
// ─────────────────────────────────────────────

model Conversation {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  type       String   @default("direct") // direct | group (future)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenant_id])
  @@index([updated_at])
  @@map("conversations")
}

model ConversationParticipant {
  id                   String       @id @default(uuid())
  tenant_id            String
  tenant               Tenant       @relation(fields: [tenant_id], references: [id])
  conversation_id      String
  conversation         Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user_id              String
  user                 User         @relation("UserConversations", fields: [user_id], references: [id])
  role                 String // parent | teacher | admin
  joined_at            DateTime     @default(now())
  last_read_message_id String?

  @@unique([conversation_id, user_id])
  @@index([tenant_id])
  @@index([user_id])
  @@index([conversation_id])
  @@map("conversation_participants")
}

model Message {
  id              String       @id @default(uuid())
  tenant_id       String
  tenant          Tenant       @relation(fields: [tenant_id], references: [id])
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender_id       String
  sender          User         @relation("MessageSender", fields: [sender_id], references: [id])
  message_type    String       @default("text") // text | image | file (future)
  content         String
  created_at      DateTime     @default(now())
  edited_at       DateTime?
  deleted_at      DateTime?

  statuses MessageStatus[]

  @@index([tenant_id])
  @@index([conversation_id])
  @@index([sender_id])
  @@index([created_at])
  @@map("messages")
}

model MessageStatus {
  id         String   @id @default(uuid())
  message_id String
  message    Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User     @relation("UserMessageStatuses", fields: [user_id], references: [id])
  status     String   @default("sent") // sent | delivered | read
  updated_at DateTime @updatedAt

  @@unique([message_id, user_id])
  @@index([message_id])
  @@index([user_id])
  @@index([status])
  @@map("message_statuses")
}
